<?xml version="1.0" encoding="UTF-8"?>
<theme>
  <formatVersion>7</formatVersion>
  <!--
   ///
   System View
   ///
   -->
   <view name="system">
      <!-- Start: Resets -->
      <text name="systemInfo">
         <visible>false</visible>
         <color>00000000</color>
      </text>
      <!-- End: Resets -->
      <image name="system-background-color" extra="true">
         <origin>0 0</origin>
         <pos>0 0</pos>
         <minSize>1 1</minSize>
         <path>${spacerImage}</path>
         <color>3a3a3a</color>
         <zIndex>0</zIndex>
      </image>
      <image name="system-background-image" extra="true" ifSubset="system-background:default|fanart|image|gamebox">
         <origin>0.5 0.5</origin>
         <pos>0.66412661 0.5</pos>
         <minSize>0.67174678 1</minSize>
         <path ifSubset="system-background:default">${systemBackgroundImage}</path>
         <path ifSubset="system-background:fanart">{random:fanart}</path>
         <path ifSubset="system-background:image">{random:image}</path>
         <path ifSubset="system-background:gamebox">{random:thumbnail}</path>
         <zIndex>0</zIndex>
      </image>
      <video name="system-background-video" extra="true" ifSubset="system-background:video">
         <origin>0.5 0.5</origin>
         <pos>0.66412661 0.5</pos>
         <minSize>0.67174678 1</minSize>
         <path>{random}</path>
         <effect>none</effect>
         <delay>0</delay>
         <zIndex>0</zIndex>
      </video>

      <image name="system-panel-background-shadow" extra="true">
         <origin>0 0</origin>
         <pos>0 0</pos>
         <size>1 1</size>
         <color>${gamelistOverlayShadowColor}</color>
         <opacity>0.2</opacity>
         <zIndex>1</zIndex>
      </image>
      <image name="system-panel-background" extra="true">
         <origin>0 0</origin>
         <pos>0 0</pos>
         <size>1 1</size>
         <color>${gamelistOverlayColor}</color>
         <zIndex>1</zIndex>
      </image>
      <image name="logo">
         <path>./_inc/systems/logos/${system.theme}.png</path>
      </image>
      <carousel name="systemcarousel">
         <origin>0 0</origin>
         <pos>0 0</pos>
         <size>1 1</size>
         <type>horizontal</type>
         <color>00000000</color>
         <logoScale>1</logoScale>
         <maxLogoCount>1</maxLogoCount>
         <defaultTransition>fade & slide</defaultTransition>
         <zIndex>2</zIndex>
         <itemTemplate>
            <container>
               <image name="system-logo-shadow">
                  <pos>0.26 0.30</pos>
                  <origin>0.5 0.5</origin>
                  <maxSize>0.75 0.75</maxSize>
                  <path>{system:logo}</path>
                  <padding>4 4 -4 -4</padding>
                  <color>00000050</color>
                  <linearSmooth>true</linearSmooth>
                  <zIndex>1</zIndex>
               </image>
               <image name="system-logo">
                  <pos>0.26 0.30</pos>
                  <origin>0.5 0.5</origin>
                  <maxSize>0.75 0.75</maxSize>
                  <path>{system:logo}</path>
                  <linearSmooth>false</linearSmooth>
                  <zIndex>2</zIndex>
               </image>
               <text name="system-name">
                  <text>{system:fullName}</text>
                  <fontPath>${logoFont}</fontPath>
                  <fontSize>0.15</fontSize><!-- 72 -->
                  <lineSpacing>0.75</lineSpacing>
                  <forceUppercase>true</forceUppercase>
                  <color>${systemLogoColor}</color>
                  <alignment>center</alignment>
                  <multiLine>true</multiLine>
                  <visible>!exists({system:logo})</visible>
                  <pos>0.26 0.30</pos>
                  <origin>0.5 0.5</origin>
               </text>
             </container>
          </itemTemplate>
      </carousel>
      <!-- Start: Release Year -->
      <text name="releaseYear" extra="true" ifSubset="release-year:on" if="!empty(${system.hardwareType}) || max(${system.releaseYearOrNull}, 0) != 0">
         <text if="max(${system.releaseYearOrNull}, 0) != 0">${system.releaseYearOrNull} · ${system.hardwareType}</text>
         <text if="max(${system.releaseYearOrNull}, 0) == 0">${system.hardwareType}</text>
         <origin>0.5 0.5</origin>
         <pos>0.165 0.6</pos>
         <size>0.33 0.05</size>
         <alignment>center</alignment>
         <forceUppercase>true</forceUppercase>
         <fontPath>${logoFont}</fontPath>
         <fontSize ifSubset="font-size:small|default">0.05</fontSize><!-- 24 -->
         <fontSize ifSubset="font-size:large">0.0625</fontSize><!-- 30 -->
         <color>${gamelistOverlayColor}</color>
         <backgroundColor>${gamelistTextlistPrimaryColor}</backgroundColor>
      </text>
      <!-- End: Release Year -->
      <!-- Start: System Count -->
      <text name="system-count,system-count-single,system-count-null" extra="true" ifSubset="system-count:on">
         <origin>0.5 0.5</origin>
         <pos>0.165 0.8</pos>
         <size>0.33 0.05</size>
         <alignment>center</alignment>
         <fontSize>0.041666666666667</fontSize>
         <fontSize ifSubset="font-size:small|default">0.075</fontSize><!-- 36 -->
         <fontSize ifSubset="font-size:large">0.1</fontSize><!-- 48 -->
         <fontPath>${logoFont}</fontPath>
         <color>ffffff</color>
      </text>
      <text name="system-count" extra="true" ifSubset="system-count:on">
         <text>{system:total} Games</text>
         <visible>{system:total} &gt; 1 ? 1 : 0</visible>
      </text>
      <text name="system-count-single" extra="true" ifSubset="system-count:on">
         <text>1 Game</text>
         <visible>{system:total} == 1 ? 1 : 0</visible>
      </text>
      <text name="system-count-null" extra="true" ifSubset="system-count:on">
         <text>0 Games</text>
         <visible>{system:total} == 0 ? 1 : 0</visible>
      </text>
      <!-- End: System Count -->
   </view>
</theme>